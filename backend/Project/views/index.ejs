<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/style/style.css">
</head>
<body>
            <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 60vh;">
                <form action="/" method="get" style="background: rgba(0,0,0,0.3); padding: 30px; border-radius: 10px; box-shadow: 0 0 10px #000;">
                    <label for="city" style="color: #fff; font-weight: bold; font-size: 1.2em;">Enter city name:</label><br>
                    <input type="text" id="city" name="city" placeholder="e.g. London" value="<%= typeof city !== 'undefined' ? city : '' %>" required style="margin: 10px 0; padding: 8px; font-size: 1em; border-radius: 5px; border: 1px solid #fff; background: #333; color: #fff;">
                    <br>
                    <button type="submit" style="padding: 10px 20px; font-size: 1em; border-radius: 5px; border: none; background: #222; color: #fff; font-weight: bold; cursor: pointer;">Get Weather</button>
                </form>
                <% if (typeof weather === 'undefined' && typeof error === 'undefined') { %>
                    <p style="color: #fff; font-size: 1.1em; margin-top: 20px;">Please enter a city name to get the weather information.</p>
                <% } %>
                <% if (typeof weather !== 'undefined' && weather) { %>
                    <h2 style="color: #fff; margin-top: 30px;">Weather in <%= weather.name %></h2>
                    <p>Temperature: <%= weather.main.temp %> °C</p>
                    <p>Weather: <%= weather.weather[0].description %></p>
                <% } else if (typeof error !== 'undefined' && error) { %>
                    <p><%= error %></p>
                <% } %>
            </div>
</body>
</body>
</html>